# ============================================
# CONFIGURACIÓN DE SUPABASE
# ============================================

# URL de tu proyecto Supabase
# Obtén esto en: Settings → API → Project URL
SUPABASE_URL=https://tu-proyecto.supabase.co

# Anon/Public Key de Supabase
# Obtén esto en: Settings → API → Project API keys → anon public
# Es una clave JWT larga que empieza con "eyJ..."
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================
# INSTRUCCIONES
# ============================================

# 1. Copia este archivo como .env
# 2. Reemplaza los valores con tus credenciales reales
# 3. NUNCA subas el archivo .env a Git
# 4. Agrega .env al .gitignore

# ============================================
# PARA PRODUCCIÓN
# ============================================

# En Vercel/Netlify/GitHub Pages:
# - Agrega estas variables en el panel de configuración
# - No uses archivos .env en producción
# - Las variables se inyectan en build time

# ============================================
# SEGURIDAD
# ============================================

# ⚠️ La ANON_KEY es segura para uso público
# ⚠️ NUNCA expongas la SERVICE_ROLE_KEY
# ⚠️ Usa RLS para proteger tus datos
